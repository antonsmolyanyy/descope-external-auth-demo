# Descope MCP server OpenID configuration URL from the Descope console.
# Example:
# https://api.descope.com/v1/apps/agentic/P.../M.../.well-known/openid-configuration
DESCOPE_CONFIG_URL=

# Public URL where this MCP server is reachable.
# On Vercel, VERCEL_URL is used automatically when BASE_URL is unset.
# For local development:
BASE_URL=http://localhost:8000

# Optional local dev port for `python demo_server.py`
PORT=8000

# Recommended for serverless deployments such as Vercel.
FASTMCP_STATELESS_HTTP=true
